# docker-compose environment template
#
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# .env is local-only and MUST NOT be committed.

# ── PostgreSQL ──────────────────────────────────────────────────

POSTGRES_USER=vpnbot
POSTGRES_PASSWORD=<change-me-to-a-strong-password>
POSTGRES_DB=vpnbot

# ── Telegram Bot ────────────────────────────────────────────────

BOT_TOKEN=<your-telegram-bot-token>

# ── Application ─────────────────────────────────────────────────

APP_ENV=production

# ── Telegram webhook ────────────────────────────────────────────

TELEGRAM_WEBHOOK_HTTP_ENABLE=1
TELEGRAM_WEBHOOK_SECRET_TOKEN=<your-webhook-secret-token>
TELEGRAM_WEBHOOK_PUBLIC_URL=https://your-domain.com/telegram/webhook
TELEGRAM_WEBHOOK_ALLOWED_UPDATES=message

# ── Web API (frontend) ──────────────────────────────────────────

WEB_API_ENABLE=1
WEB_API_CORS_ORIGINS=https://your-domain.com

# ── Storefront ──────────────────────────────────────────────────

TELEGRAM_STOREFRONT_CHECKOUT_URL=https://your-domain.com/offer
TELEGRAM_STOREFRONT_RENEWAL_URL=https://your-domain.com/payment
TELEGRAM_STOREFRONT_SUPPORT_URL=https://t.me/bravada_support
TELEGRAM_STOREFRONT_PLAN_NAME=Bravada VPN
TELEGRAM_STOREFRONT_PLAN_PRICE=от 300 ₽

# ── Payment ─────────────────────────────────────────────────────

PAYMENT_FULFILLMENT_HTTP_ENABLE=1
PAYMENT_FULFILLMENT_WEBHOOK_SECRET=<your-payment-webhook-secret>
TELEGRAM_CHECKOUT_REFERENCE_SECRET=<your-checkout-reference-secret>
TELEGRAM_CHECKOUT_REFERENCE_MAX_AGE_SECONDS=604800

# ── Access ──────────────────────────────────────────────────────

TELEGRAM_ACCESS_RESEND_ENABLE=1

# ── Subscription ────────────────────────────────────────────────

SUBSCRIPTION_DEFAULT_PERIOD_DAYS=30

# ── SMTP email ──────────────────────────────────────────────────

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=1

# ── Frontend ────────────────────────────────────────────────────

NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://your-domain.com

# ── Ports (optional overrides) ──────────────────────────────────

BACKEND_PORT=8000
FRONTEND_PORT=3000
