# Production environment template
# Copy to .env on the server and fill in real values.
# This file MUST NOT be committed to git.

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_USER=vpnbot
POSTGRES_PASSWORD=<strong-password-here>
POSTGRES_DB=vpnbot

# ── Telegram Bot ────────────────────────────────────────────────
BOT_TOKEN=<your-telegram-bot-token>

# ── Application ─────────────────────────────────────────────────
APP_ENV=production

# ── Telegram webhook ────────────────────────────────────────────
TELEGRAM_WEBHOOK_HTTP_ENABLE=1
TELEGRAM_WEBHOOK_SECRET_TOKEN=<your-webhook-secret-token>
TELEGRAM_WEBHOOK_PUBLIC_URL=https://bravada-connect.ru/telegram/webhook
TELEGRAM_WEBHOOK_ALLOWED_UPDATES=message

# ── Web API (frontend) ──────────────────────────────────────────
WEB_API_ENABLE=1
WEB_API_CORS_ORIGINS=https://bravada-connect.ru

# ── Storefront ──────────────────────────────────────────────────
TELEGRAM_STOREFRONT_CHECKOUT_URL=https://bravada-connect.ru
TELEGRAM_STOREFRONT_RENEWAL_URL=https://bravada-connect.ru
TELEGRAM_STOREFRONT_SUPPORT_URL=https://t.me/bravada_support
TELEGRAM_STOREFRONT_PLAN_NAME=Bravada VPN
TELEGRAM_STOREFRONT_PLAN_PRICE=от 300 ₽

# ── Payment ─────────────────────────────────────────────────────
PAYMENT_FULFILLMENT_HTTP_ENABLE=1
PAYMENT_FULFILLMENT_WEBHOOK_SECRET=<your-payment-webhook-secret>
TELEGRAM_CHECKOUT_REFERENCE_SECRET=<your-checkout-reference-secret>
TELEGRAM_CHECKOUT_REFERENCE_MAX_AGE_SECONDS=604800

# ── Access ──────────────────────────────────────────────────────
TELEGRAM_ACCESS_RESEND_ENABLE=1

# ── Subscription ────────────────────────────────────────────────
SUBSCRIPTION_DEFAULT_PERIOD_DAYS=30

# ── Frontend ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://bravada-connect.ru
NEXT_PUBLIC_API_URL=https://bravada-connect.ru

# ── Bot username ────────────────────────────────────────────────
BOT_USERNAME=bravadavpn_bot

# ── SMTP email ──────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=1

# ── JWT / auth ──────────────────────────────────────────────────
JWT_SECRET=
JWT_TTL_HOURS=
EMAIL_CODE_TTL_MINUTES=

# ── Ports (optional overrides) ──────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── 3x-ui Panel ─────────────────────────────────────────────────
XUI_ENABLED=1
XUI_VERIFY_SSL=1
FIELD_ENCRYPTION_KEY=<base64-encoded-32-byte-key>

# ── YooKassa ─────────────────────────────────────────────────────
YOOKASSA_SHOP_ID=<your-shop-id>
YOOKASSA_API_KEY=<your-api-key>
YOOKASSA_WEBHOOK_SECRET=<your-webhook-secret-from-yookassa-dashboard>

# ── Internal API ────────────────────────────────────────────────
INTERNAL_API_SECRET=<generate-a-random-secret>

# ── Admin endpoints ──────────────────────────────────────────────
ADM_INTERNAL_SECRET=<generate-a-random-secret>

# ── Subscription URL ────────────────────────────────────────────
SUBSCRIPTION_BASE_URL=https://bravada-connect.ru
